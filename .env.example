AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

OPENSEARCH_ENDPOINT=your-collection.us-east-1.aoss.amazonaws.com
OPENSEARCH_INDEX=rag-knowledge-base

MEMORY_TABLE=rag-conversation-memory
EMBEDDING_CACHE_TABLE=rag-embedding-cache
DEDUP_TABLE=rag-chunk-dedup

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVE=10
TOP_K_RERANK=4
SIMILARITY_THRESHOLD=0.7

MAX_TOKENS=1024
TEMPERATURE=0.1
SESSION_TTL_HOURS=24

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=rag-pipeline

STAGE=dev
